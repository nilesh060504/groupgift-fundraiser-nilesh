PORT=5000

# MongoDB Atlas (recommended for production)
# Create cluster → Database Access (user) → Network Access (allow current IP or 0.0.0.0/0 for testing)
# Password with @ # etc. must be URL-encoded in the URI
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Local MongoDB (development only)
# MONGO_URI=mongodb://127.0.0.1:27017/groupgift

JWT_SECRET=use_a_long_random_secret_in_production
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,https://groupgift-fundraiser.vercel.app
DEFAULT_UPI_ID=yourname@paytm
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=GroupGift <no-reply@groupgift.app>
